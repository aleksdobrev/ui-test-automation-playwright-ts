{
  "name": "ui-test-automation-playwright-ts",
  "version": "1.0.0",
  "description": "ui test automation with playwright and typescript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --workers=1",
    "test:chrome": "npx playwright test --project=chromium --workers=1",
    "test:firefox": "npx playwright test --project=firefox --workers=1",
    "test:safari": "npx playwright test --project=webkit --workers=1",
    "test:smoke": "npx playwright test --grep @smoke --workers=1",
    "test:regression": "npx playwright test --grep @regression --workers=1",
    "test:login-page": "npx playwright test --grep @login-page --workers=1",
    "test:products-list": "npx playwright test --grep @products-list --workers=1",
    "test:product-details": "npx playwright test --grep @product-details --workers=1",
    "report": "npx playwright show-report",
    "test:mobile-view": "npx playwright test --config=mobile-view.config.ts --workers=1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleksdobrev/ui-test-automation-playwright-ts.git"
  },
  "author": "aleksdobrev",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/aleksdobrev/ui-test-automation-playwright-ts/issues"
  },
  "homepage": "https://github.com/aleksdobrev/ui-test-automation-playwright-ts#readme",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0"
  }
}
